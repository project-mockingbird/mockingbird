node_modules/
dist/
src/web/node_modules/
src/web/out/
src/web/.next/
*.tsbuildinfo
.env
.env.local
.env.*.local
data/

# Bind-mount roots - populated at runtime from an external SCS project tree
# and must never be committed here.
content/
serialization/

# Test fixtures may legitimately contain path segments named "content" or
# "serialization" (e.g. extracted Sitecore package fixtures whose entries
# mirror /sitecore/content/...). Override the ignores above for the fixtures
# tree.
!tests/fixtures/**

# Engine source directory that happens to be named "serialization" - it is
# committed source code, not a bind-mount root. Negate the directory itself
# so git descends into it (per-file negations don't work on excluded dirs).
!src/engine/serialization

# Local scratch space.
/.scratch/

# Claude Code / superpowers local config.
/.claude/
/.superpowers/

# Brainstorming spec docs and implementation plans are local-only working artifacts.
/docs/superpowers/specs/
/docs/superpowers/plans/

# Personal task backlog.
/backlog.md
/backlog-archive.md

# Local dev-loop docker-compose overlay.
/docker-compose.dev.yml

# C# provider build output (also covered by /data/ but listed explicitly).
/data/spe/
# C# build intermediates (per-project bin/ and obj/ under src/spe/provider-csharp).
src/spe/provider-csharp/**/bin/
src/spe/provider-csharp/**/obj/
.mockingbird/

# Operational scripts (launch-prep, ops, ad-hoc). Existing tracked scripts in
# scripts/ (dedupe-react.mjs, lint-graphql-context.mjs, etc.) stay tracked;
# Maintainer-local helper scripts (release tooling, ad-hoc inspect/extract
# utilities, credentials via scripts/.env.local). The whole folder is local
# by default - the three files below are exceptions because they're load-
# bearing for `npm test` / `npm run build:provider` and have to ship to any
# fresh clone.
/scripts/
!scripts/build-provider.mjs
!scripts/dedupe-react.mjs
!scripts/lint-graphql-context.mjs

# config.mockingbird at the repo root is a dev/smoke artifact when this repo is
# used as its own workspace mount. In normal user projects the file is meant
# to be committed (team-shared project registry), but for mockingbird-the-tool
# we keep it untracked so smoke sessions don't pollute git.
config.mockingbird

# Per-developer session state (lastOpenedHash, per-project lastOpenedAt).
# Always untracked - lives next to config.mockingbird in user projects too.
# Consumer repos that commit config.mockingbird should add this line to
# their own .gitignore.
config.mockingbird.local
