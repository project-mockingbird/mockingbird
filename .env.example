COMPOSE_PROJECT_NAME=mockingbird

# Mockingbird settings
MOCKINGBIRD_PORT=3333
MOCKINGBIRD_HOST=0.0.0.0

# Writable cache directory. Safe to delete; rebuilds on next boot.
MOCKINGBIRD_CACHE_PATH=./data/cache

# ---------------------------------------------------------------------------
# Path config - docker (docker compose up):
#   docker-compose.yml bind-mounts the host project root(s) at /scs and
#   /scs-content, then sets SCS_SITECORE_JSON and SCS_CONTENT_SITECORE_JSON
#   inside the container to the matching container paths. You only set the
#   host-side bind sources here.
# ---------------------------------------------------------------------------
SCS_ROOT=./
SCS_CONTENT_ROOT=./content

# ---------------------------------------------------------------------------
# Path config - docker (docker-compose.openrepo.yml, Open Repository mode):
#   The openrepo compose template binds MOCKINGBIRD_WORKSPACE_HOST -> /workspaces.
#   The web UI's first-run wizard walks that mount to discover sitecore.json
#   files at runtime. Defaults to the directory you ran compose from (./).
#   Override to a broader directory if your authoring repos live elsewhere.
# ---------------------------------------------------------------------------
MOCKINGBIRD_WORKSPACE_HOST=./

# Layout Service / GraphQL endpoint settings
# Sitecore path of your site's start item, e.g. /sitecore/content/<tenant>/<site>/Home.
# Used as the synthetic-fallback site root when no real Site Grouping item in the
# content tree matches the request's `?site=` argument or `Host:` header. The Web UI's
# "site" name is auto-derived from the penultimate path segment (here: <site>).
# Leave empty if your content tree already has Site Grouping items covering every
# request - the fallback rung doesn't fire and the path isn't read.
SITE_ROOT_PATH=/sitecore/content/<tenant>/<site>/Home
# Security knobs - all default to safe values; only set when integrating with
# a hosted UI on a different origin or when raising the GraphQL depth cap for
# a deeply-nested client query.
# Comma-separated full origins (scheme://host[:port]) allowed for cross-origin
# /api/* requests. Empty = same-origin only (browser tabs from a different
# origin are rejected, non-browser callers like the CLI / curl still work).
MOCKINGBIRD_ALLOWED_ORIGINS=
# Comma-separated full origins allowed to upgrade /ws WebSocket connections.
# Empty = same-origin only. Browsers always send Origin on WS upgrades; CLI
# clients without an Origin header are always allowed.
MOCKINGBIRD_WS_ALLOWED_ORIGINS=
# Maximum GraphQL query depth before mercurius rejects with a depth error.
# Default 20 covers the consuming-app ModularNavigation query verbatim.
MOCKINGBIRD_GRAPHQL_QUERY_DEPTH=20

# PowerShell scripting (SPE) tuning. The feature is always on; these knobs
# exist for sites that need to bound resource use.
# Per-session TTL in minutes (default 30). Idle sessions are reaped.
MOCKINGBIRD_SPE_SESSION_TTL_MIN=30
# Concurrent session cap (default 8). New sessions beyond the cap return 429.
MOCKINGBIRD_SPE_MAX_SESSIONS=8
