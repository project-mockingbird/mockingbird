# Optional - override the docker compose container name.
# COMPOSE_PROJECT_NAME=mockingbird

# Host directory bound at /workspaces inside the container. The first-run
# wizard walks this mount to discover sitecore.json files at runtime.
# Defaults to the directory you ran compose from (./).
# Override to a broader directory if your authoring repos live elsewhere
# (e.g. C:/projects on Windows, ~/code on macOS/Linux).
MOCKINGBIRD_WORKSPACE_HOST=./

# Port mockingbird binds to on the host (loopback-only). The container
# always listens on 3333 internally.
# MOCKINGBIRD_PORT=3333

# Layout Service / GraphQL endpoint settings
# Sitecore path of your site's start item, used as the synthetic-fallback
# site root when no real Site Grouping item in the content tree matches
# the request. Leave unset when configuring per-project at runtime.
# SITE_ROOT_PATH=/sitecore/content/<tenant>/<site>/Home

# Security knobs - all default to safe values; only set when integrating
# with a hosted UI on a different origin or when raising the GraphQL depth
# cap for a deeply-nested client query.
# Comma-separated full origins (scheme://host[:port]) allowed for cross-origin
# /api/* requests. Empty = same-origin only (browser tabs from a different
# origin are rejected, non-browser callers like the CLI / curl still work).
# MOCKINGBIRD_ALLOWED_ORIGINS=
# Comma-separated full origins allowed to upgrade /ws WebSocket connections.
# MOCKINGBIRD_WS_ALLOWED_ORIGINS=
# Maximum GraphQL query depth before mercurius rejects with a depth error.
# MOCKINGBIRD_GRAPHQL_QUERY_DEPTH=20

# PowerShell scripting (SPE) tuning. The feature is always on; these knobs
# exist for sites that need to bound resource use.
# Per-session TTL in minutes (default 30). Idle sessions are reaped.
# MOCKINGBIRD_SPE_SESSION_TTL_MIN=30
# Concurrent session cap (default 8). New sessions beyond the cap return 429.
# MOCKINGBIRD_SPE_MAX_SESSIONS=8
