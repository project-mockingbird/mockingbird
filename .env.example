# Optional - override the docker compose container name.
# COMPOSE_PROJECT_NAME=mockingbird

# Host directory bound at /workspaces inside the container. The first-run
# wizard walks this mount to discover sitecore.json files at runtime.
# Defaults to the directory you ran compose from (./).
# Override to a broader directory if your authoring repos live elsewhere
# (e.g. C:/projects on Windows, ~/code on macOS/Linux).
MOCKINGBIRD_WORKSPACE=./

MOCKINGBIRD_IMAGE=projectmockingbird/mockingbird:latest

# Host-side port mockingbird is accessible on (bound to loopback only).
# The container always listens on 3333 internally.
MOCKINGBIRD_PORT=3333
MOCKINGBIRD_HOST=0.0.0.0

# Layout Service / GraphQL endpoint settings
# Sitecore path of your site's start item, used as the synthetic-fallback
# site root when no real Site Grouping item in the content tree matches
# the request. Leave unset when configuring per-project at runtime.
# SITE_ROOT_PATH=/sitecore/content/<tenant>/<site>/Home
